# Copy this file to .env.local and fill in your keys
# DO NOT commit .env.local to git

# Tavily Search API — free at https://tavily.com/
# Free tier: 1000 credits/month, no credit card needed
# 1 search = 1 credit
TAVILY_API_KEY=your_tavily_api_key_here

# OpenRouter API — free at https://openrouter.ai/
# Free models include: google/gemma-4-26b-a4b-it
OPENROUTER_API_KEY=your_openrouter_api_key_here
